# Backend
DATABASE_URL=postgresql+asyncpg://user:password@host/paperstack?sslmode=require
DEV_DATABASE_URL=postgresql+asyncpg://paperstack:paperstack@localhost:5432/paperstack
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
JWT_SECRET=replace_with_64_char_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30
FRONTEND_URL=http://localhost:5173
ENCRYPTION_KEY=replace_with_32_char_random_string_for_aes256

# LLM / RAG (in-house keys for auto-highlight fallback and embeddings)
GLM_API_KEY=your_glm_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDING_KEY=your_gemini_api_key_for_embeddings

# Frontend (prefix with VITE_ for Vite exposure)
VITE_API_URL=http://localhost:8000/v1
VITE_GITHUB_CLIENT_ID=your_github_client_id
